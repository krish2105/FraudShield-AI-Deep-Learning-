# FraudShield AI — environment configuration (Phase 4/5)
# Copy to .env and adjust. All values have safe local defaults; the demo runs
# with NONE of these set.

# Persistence. SQLite by default; point at Postgres in production.
# FRAUDSHIELD_DATABASE_URL=postgresql+psycopg2://fraud:fraud@localhost:5432/fraudshield

# API auth. If set, scoring/training/dataset endpoints require:  X-API-Key: <value>
# Leave empty for an open local demo.
# FRAUDSHIELD_API_KEY=change-me

# Rate limit for scoring endpoints (requests per minute per client).
# FRAUDSHIELD_RATE_LIMIT=120/minute

# Comma-separated CORS origins ("*" for the demo).
# FRAUDSHIELD_CORS_ORIGINS=*

# Persist every score to the audit DB (1/0).
# FRAUDSHIELD_PERSIST_SCORES=1
